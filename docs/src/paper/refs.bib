@article{schutzoverviewicesatmission2005,
  title      = {Overview of the {{ICESat Mission}}},
  author     = {Schutz, B. E. and Zwally, H. J. and Shuman, C. A. and
                Hancock, D. and DiMarzio, J. P.},
  year       = {2005},
  journal    = {Geophys. Res. Lett.},
  volume     = {32},
  number     = {21},
  issn       = {1944-8007},
  doi        = {10/bzbspg},
  url        = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2005GL024009%4010.1002/%28ISSN%291944-8007.ICESAT1},
  urldate    = {2020-08-19},
  abstract   = {The Geoscience Laser Altimeter System (GLAS) on the NASA
                Ice, Cloud and land Elevation Satellite (ICESat) has
                provided a view of the Earth in three dimensions with
                unprecedented accuracy. Although the primary objectives
                focus on polar ice sheet mass balance, the GLAS
                measurements, distributed in 15 science data products, have
                interdisciplinary application to land topography,
                hydrology, vegetation canopy heights, cloud heights and
                atmospheric aerosol distributions. Early laser life issues
                have been mitigated with the adoption of 33-day operation
                periods, three times per year, designed to document intra-
                and inter-annual polar ice changes in accordance with
                mission requirements. A variety of calibration/validation
                experiments have been executed which show that the
                elevation products, when fully calibrated, have an accuracy
                that meets the science requirements. The series of papers
                in this special ICESat issue demonstrate the utility and
                quality of the ICESat data.},
  copyright  = {Copyright 2005 by the American Geophysical Union.},
  langid     = {english},
  annotation = {477 citations (Crossref) [2022-01-19]\\ ZSCC: 0000689}
}

